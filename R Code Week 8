# Create a new dataset consisting of a string of numbers to practice outlier handling
data <- c(30,24,26,28,29,28,27,26,32,34,13,15,14,31,29,28,24,25,30,34,35,27,30,34,44,48)

# Create a boxplot to visually spot outliers
boxplot(data, main = "Boxplot")

# Sort the data from lowest to highest
sort(data)

# Print summary statistics to see quartiles and mean
summary(data)

# Calculate the Interquartile Range (IQR) to help define outliers
iqr <- IQR(data)

# Find the first quartile (25th percentile)
first_q <- quantile(data, 0.25)

# Find the third quartile (75th percentile)
third_q <- quantile(data, 0.75)

# Define the lower threshold (lower edge) for outliers using the 1.5 * IQR rule
le <- first_q - 1.5 * iqr

# Define the upper threshold (upper edge) for outliers using the 1.5 * IQR rule
ue <- third_q + 1.5 * iqr

# View the calculated lower edge value
View(le)

# Create a copy of the data to begin manipulating outliers
data_new <- data

# Method 1: Remove the outliers entirely by keeping only data within the fences
data_new <- data_new[!data_new < le]
data_new <- data_new[!data_new > ue]

# Print the data to see the results after removal
data_new

# Reset 'data_new' back to the original set containing outliers
data_new <- data

# Calculate a rounded average of the data for imputation
avg <- round(mean(data_new)) # for the purpose of example we round up value

# Method 2: Replace values below the lower edge and above the upper edge with the mean
data_new[data_new < le] <- avg
data_new[data_new > ue] <- avg

# Print the data to see the results after mean replacement
data_new

# Reset 'data_new' back to the original set again
data_new <- data

# Method 3: 'Winsorizing' (Cap the outliers at the upper and lower fence values)
data_new[data_new < le] <- le
data_new[data_new > ue] <- ue

# Print the data to see the results after Winsorizing
data_new

# Plot a new boxplot to verify the outliers have been successfully handled
boxplot(data_new, main = "Boxplot")

